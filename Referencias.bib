  year = {1986},
  volume = {323},
  pages = {533-536},
  number = {Oct},
  abstract = {Describes back-propagation, which is a set of learning rules for neural
	networks. The procedure repeatedly adjusts the weights of the connections
	in the network so as to minimize a measure of the difference between
	the actual output vector of the net and the desired output vector.
