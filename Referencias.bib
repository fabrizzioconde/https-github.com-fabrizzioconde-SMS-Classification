  volume = {74},
  pages = {560-4},
  number = {2},
  abstract = {DNA can be sequenced by a chemical procedure that breaks a terminally
	labeled DNA molecule partially at each repetition of a base. The
	lengths of the labeled fragments then identify the positions of that
	base. We describe reactions that cleave DNA preferentially at guanines,
	at adenines, at cytosines and thymines equally, and at cytosines
	alone. When the products of these four reactions are resolved by
